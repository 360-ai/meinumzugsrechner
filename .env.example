# Öffentliche App-URL (ohne trailing slash). In Production z. B. https://meinumzugsrechner.de
# Wichtig für Canonical-URLs, Sitemap, Open Graph und JSON-LD.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Stripe — https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Optional: festes Price-ID aus dem Stripe-Dashboard (EUR 2,99 einmalig).
# Wenn leer, wird der Betrag inline als price_data gesetzt (Checkout).
STRIPE_PRICE_ID=

# Webhook — https://dashboard.stripe.com/webhooks (Endpoint-Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Cloudflare Workers (Production) ---
# Diese Variablen im Cloudflare Dashboard unter Workers → Settings → Variables setzen
# (gleiche Namen wie oben). Lokal: npm run dev. Worker-Preview: npm run preview:cf
# Deploy: npm run deploy:cf (nach wrangler login)
